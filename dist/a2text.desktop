[Desktop Entry]
Name=a2text
Comment=Voice-to-text dictation daemon
Exec=/usr/local/bin/a2text
Icon=audio-input-microphone
Type=Application
Categories=Utility;Accessibility;
# NoDisplay keeps the app out of the launcher while still registering it with
# xdg-desktop-portal, which resolves the caller's app ID by matching
# /proc/<pid>/exe against Exec= lines in installed .desktop files.
NoDisplay=true
Keywords=voice;dictation;transcription;speech;
